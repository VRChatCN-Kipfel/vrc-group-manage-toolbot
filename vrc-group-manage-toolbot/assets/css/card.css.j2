/* 近星层 */
.starfield-near {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.star {
    position: absolute;
    width: 2.5px;
    height: 2.5px;
    border-radius: 50%;
    background: currentColor;
    color: rgba(255,255,255,0.9);
    animation: twinkle 5s ease-in-out infinite;
    box-shadow: 0 0 4px currentColor;
}

.star:nth-child(7n)  { animation-delay: -1.43s; }
.star:nth-child(11n) { animation-delay: -2.71s; }
.star:nth-child(13n) { animation-delay: -3.89s; }
.star:nth-child(17n) { animation-delay: -1.03s; }
.star:nth-child(19n) { animation-delay: -4.57s; }
.star:nth-child(23n) { animation-delay: -2.33s; }

.star:nth-child(7n)  { color: var(--accent-1); box-shadow: 0 0 6px rgba(var(--accent-1-rgb), 0.6); }
.star:nth-child(11n) { color: var(--accent-2); box-shadow: 0 0 6px rgba(var(--accent-2-rgb), 0.6); }
.star:nth-child(13n) { color: var(--accent-3); box-shadow: 0 0 6px rgba(var(--accent-3-rgb), 0.6); }
.star:nth-child(17n) { color: rgba(var(--accent-1-rgb), 0.8); box-shadow: 0 0 6px rgba(var(--accent-1-rgb), 0.5); }
.star:nth-child(19n) { color: rgba(var(--accent-2-rgb), 0.8); box-shadow: 0 0 6px rgba(var(--accent-2-rgb), 0.5); }

.star:nth-child(29n) { transform: scale(1.4); }
.star:nth-child(31n) { transform: scale(0.7); opacity: 0.6; }
.star:nth-child(37n) { transform: scale(1.6); }

@keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
}

/* ========== 页面基底 ========== */
body {
    margin: 0;
    padding: 20px;
    background-color: {{ bg_color }};
    font-family: "Microsoft YaHei", "SimHei", sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow-x: hidden;
}

/* ========== 卡片 ========== */
.card {
    position: relative;
    max-width: 760px;
    width: 100%;
    border-radius: 24px;
    padding: 36px;
    z-index: 1;
    overflow: hidden;
    background: {{ card_bg }};
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid {{ border_color }};
    box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.5),
        0 0 0 1px rgba(var(--accent-2-rgb), 0.08),
        inset 0 0 30px rgba(var(--accent-2-rgb), 0.04);
}

/* 装饰线：仅在 decorations=true 时生效 */
.card--decorated::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-1) 0%, var(--accent-2) 35%, var(--accent-3) 65%, var(--accent-1) 100%);
    opacity: 0.9;
    z-index: 2;
    box-shadow: 0 0 16px rgba(var(--accent-2-rgb), 0.35);
}

/* 内部顶部柔和辉光 */
.card-glow {
    position: absolute;
    top: -40%;
    left: 10%;
    width: 80%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(var(--accent-2-rgb), 0.06), transparent 60%);
    pointer-events: none;
    z-index: 0;
}

/* ========== 标题 ========== */
.title {
    font-size: 27px;
    font-weight: bold;
    color: {{ title_color }};
    margin-bottom: 22px;
    padding-bottom: 16px;
    position: relative;
    letter-spacing: 0.6px;
    text-shadow: 0 0 18px rgba(var(--accent-1-rgb), 0.25);
    z-index: 1;
}

.card--decorated .title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-1) 0%, var(--accent-2) 45%, rgba(var(--accent-3-rgb), 0.2) 85%, transparent 100%);
    border-radius: 1px;
    opacity: 0.8;
}

/* ========== 内容 ========== */
.content {
    font-size: 16px;
    color: {{ text_color }};
    line-height: 1.85;
    margin-bottom: 22px;
    position: relative;
    z-index: 1;
}

.content p { margin: 0 0 14px; }
.content ul { margin: 0 0 14px; padding-left: 22px; }
.content li { margin-bottom: 8px; }
.content strong { color: {{ title_color }}; }
.content a {
    color: var(--accent-3);
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-3-rgb), 0.3);
    transition: all 0.2s;
}
.content a:hover {
    color: var(--accent-1);
    border-bottom-color: var(--accent-1);
    text-shadow: 0 0 8px rgba(var(--accent-1-rgb), 0.3);
}
.content code {
    background: rgba(var(--accent-2-rgb), 0.12);
    color: var(--accent-1);
    padding: 2px 7px;
    border-radius: 5px;
    font-family: "SF Mono", Monaco, monospace;
    font-size: 14px;
    border: 1px solid rgba(var(--accent-2-rgb), 0.2);
}

.card--decorated .content::before {
    content: "";
    position: absolute;
    left: -24px;
    top: 8px;
    bottom: 8px;
    width: 3px;
    background: linear-gradient(to bottom, var(--accent-1), var(--accent-2), var(--accent-3), transparent);
    border-radius: 3px;
    opacity: 0.55;
}

/* ========== 页脚 ========== */
.footer {
    font-size: 13px;
    color: {{ footer_color }};
    text-align: right;
    margin-top: 22px;
    padding-top: 14px;
    position: relative;
    z-index: 1;
}

.card--decorated .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 35%;
    right: 0;
    height: 1.5px;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--accent-3-rgb), 0.4) 30%, rgba(var(--accent-2-rgb), 0.6) 60%, var(--accent-1) 100%);
    border-radius: 1px;
    opacity: 0.7;
}
