/* ========== CSS 自定义属性：主题色系统 ========== */
:root {
    --accent-1: {{ accent_1 | default('#7fffd4') }};
    --accent-2: {{ accent_2 | default('#39c5bb') }};
    --accent-3: {{ accent_3 | default('#40e0d0') }};
    --accent-1-rgb: {{ accent_1_rgb | default('127, 255, 212') }};
    --accent-2-rgb: {{ accent_2_rgb | default('57, 197, 187') }};
    --accent-3-rgb: {{ accent_3_rgb | default('64, 224, 208') }};
}

/* ========== 字体定义 ========== */
{% if font_url %}
@font-face {
    font-family: "CustomFont";
    src: url("{{ font_url }}")
        {% if font_url.endswith('.woff2') %}format("woff2"){% 
        elif font_url.endswith('.ttf') %}format("truetype"){% 
        elif font_url.endswith('.otf') %}format("opentype"){% 
        elif font_url.endswith('.woff') %}format("woff"){% 
        endif %};
    font-weight: {{ font_weight | default(400) }};
    font-display: swap;
}
{% endif %}

/* ========== 星空背景层 ========== */
.bg-stars {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background:
        radial-gradient(ellipse 90% 60% at 20% 80%, rgba(var(--accent-1-rgb), 0.05) 0%, transparent 60%),
        radial-gradient(ellipse 70% 80% at 75% 20%, rgba(var(--accent-2-rgb), 0.04) 0%, transparent 55%),
        radial-gradient(ellipse 60% 50% at 50% 50%, rgba(var(--accent-3-rgb), 0.03) 0%, transparent 50%),
        radial-gradient(ellipse 100% 70% at 85% 85%, rgba(var(--accent-1-rgb), 0.03) 0%, transparent 55%),
        radial-gradient(ellipse at bottom, #121820 0%, {{ bg_color }} 100%);
    overflow: hidden;
}

