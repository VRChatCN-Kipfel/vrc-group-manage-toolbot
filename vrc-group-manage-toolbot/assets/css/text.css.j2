/* 近星层 */
.starfield-near {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.star {
    position: absolute;
    width: 2.5px;
    height: 2.5px;
    border-radius: 50%;
    background: currentColor;
    color: rgba(255,255,255,0.9);
    animation: twinkle 5s ease-in-out infinite;
    box-shadow: 0 0 4px currentColor;
}

.star:nth-child(7n)  { animation-delay: -1.43s; color: var(--accent-1); box-shadow: 0 0 6px rgba(var(--accent-1-rgb), 0.6); }
.star:nth-child(11n) { animation-delay: -2.71s; color: var(--accent-2); box-shadow: 0 0 6px rgba(var(--accent-2-rgb), 0.6); }
.star:nth-child(13n) { animation-delay: -3.89s; color: var(--accent-3); box-shadow: 0 0 6px rgba(var(--accent-3-rgb), 0.6); }
.star:nth-child(17n) { animation-delay: -1.03s; color: rgba(var(--accent-1-rgb), 0.8); box-shadow: 0 0 6px rgba(var(--accent-1-rgb), 0.5); }
.star:nth-child(19n) { animation-delay: -4.57s; color: rgba(var(--accent-2-rgb), 0.8); box-shadow: 0 0 6px rgba(var(--accent-2-rgb), 0.5); }
.star:nth-child(29n) { transform: scale(1.4); }
.star:nth-child(31n) { transform: scale(0.7); opacity: 0.6; }
.star:nth-child(37n) { transform: scale(1.6); }

@keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
}

/* ========== 页面基底 ========== */
body {
    margin: 0;
    padding: 0;
    background-color: {{ bg_color }};
    font-size: {{ font_size | default(15) }}px;
    color: {{ text_color }};
    font-family: {% if font_url %}"CustomFont", {% endif %}{{ font_family | default('"Microsoft YaHei", "SimHei", sans-serif') }};
    line-height: 1.85;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow-x: hidden;
}

/* ========== 文本面板 ========== */
.text-panel {
    position: relative;
    max-width: 720px;
    width: 100%;
    border-radius: 20px;
    padding: {{ padding | default(40) }}px {{ padding | default(40) + 8 }}px;
    z-index: 1;
    overflow: hidden;
    background: {{ panel_bg | default('rgba(10, 18, 30, 0.42)') }};
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid {{ border_color }};
    box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.5),
        0 0 0 1px rgba(var(--accent-2-rgb), 0.08),
        inset 0 0 30px rgba(var(--accent-2-rgb), 0.04);
}

/* 装饰线：仅在 decorations=true 时生效 */
.text-panel--decorated::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-1) 0%, var(--accent-2) 35%, var(--accent-3) 65%, var(--accent-1) 100%);
    opacity: 0.9;
    z-index: 2;
    box-shadow: 0 0 16px rgba(var(--accent-2-rgb), 0.35);
}

/* 内部辉光 */
.text-panel-glow {
    position: absolute;
    top: -40%;
    left: 10%;
    width: 80%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(var(--accent-2-rgb), 0.06), transparent 60%);
    pointer-events: none;
    z-index: 0;
}

/* 左侧装饰线 */
.text-panel--decorated::after {
    content: "";
    position: absolute;
    left: 0;
    top: 60px;
    bottom: 60px;
    width: 3px;
    background: linear-gradient(to bottom, var(--accent-2), transparent);
    border-radius: 0 3px 3px 0;
    opacity: 0.5;
}

/* ========== 文本内容 ========== */
.content {
    width: 100%;
    word-wrap: break-word;
    position: relative;
    z-index: 1;
    text-shadow: 0 0 2px rgba(0,0,0,0.3);
}

.content p {
    margin: 0 0 16px;
}

.content p:last-child {
    margin-bottom: 0;
}

.content a {
    color: var(--accent-3);
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-3-rgb), 0.3);
    transition: all 0.2s;
}
.content a:hover {
    color: var(--accent-1);
    border-bottom-color: var(--accent-1);
    text-shadow: 0 0 8px rgba(var(--accent-1-rgb), 0.3);
}

.content code {
    background: rgba(var(--accent-2-rgb), 0.12);
    color: var(--accent-1);
    padding: 2px 7px;
    border-radius: 5px;
    font-family: "SF Mono", Monaco, "Cascadia Code", monospace;
    font-size: 13.5px;
    border: 1px solid rgba(var(--accent-2-rgb), 0.2);
}

.content strong,
.content b {
    color: var(--accent-1);
    font-weight: 600;
}

.content blockquote,
.content .quote {
    margin: 16px 0;
    padding: 12px 20px;
    border-left: 3px solid var(--accent-2);
    background: rgba(var(--accent-2-rgb), 0.06);
    border-radius: 0 8px 8px 0;
    color: rgba(var(--accent-1-rgb), 0.8);
    font-style: italic;
}

.content hr,
.content .divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(var(--accent-2-rgb), 0.4), transparent);
    margin: 24px 0;
}

.content ul,
.content ol {
    margin: 0 0 16px;
    padding-left: 24px;
}
.content li {
    margin-bottom: 8px;
}
.content ul li::marker {
    color: var(--accent-2);
}

.content .meta,
.content .timestamp {
    font-size: 12px;
    color: rgba(var(--accent-2-rgb), 0.7);
    letter-spacing: 0.5px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid rgba(var(--accent-2-rgb), 0.2);
    text-align: right;
}