<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        {{ css | safe }}
    </style>
</head>
<body>
    <div class="card">
        <div class="title">{{ title }}</div>
        <div class="content">{{ content | safe }}</div>
        {% if footer %}
        <div class="footer">{{ footer }}</div>
        {% endif %}
    </div>
</body>
</html>
