# NoneBot2 配置
HOST=127.0.0.1
PORT=40796

# OneBot V11 配置
ONEBOT_ACCESS_TOKEN=""

# OneBot V11 连接方式配置（反向 WebSocket）
# 使用反向 WebSocket 时，OneBot 实现会主动连接到 NoneBot
# NoneBot 会在 ws://HOST:PORT/onebot/v11/ws 路径上监听
ONEBOT_WS_CONNECTION_TYPE=reverse

# 日志级别
LOG_LEVEL=DEBUG

# 超级用户（填写你的 QQ 号）
SUPERUSERS=[""]

# 命令前缀
COMMAND_START=["/","!",""]

# VRChat API 配置
VRC_USERNAME=""
VRC_PASSWORD=""
VRC_AUTH_COOKIE=""
VRC_TIMEOUT=30
VRC_REQUEST_DELAY=1000
