# NoneBot2 配置
HOST=127.0.0.1
PORT=40796

# OneBot V11 配置
ONEBOT_ACCESS_TOKEN=""
ONEBOT_HEARTBEAT_INTERVAL=30

# OneBot V11 连接方式配置（反向 WebSocket）
ONEBOT_WS_CONNECTION_TYPE=reverse

# 日志级别
LOG_LEVEL=DEBUG

# 超级用户（填写你的 QQ 号）
SUPERUSERS=[""]

# 命令前缀（推荐用 #，QQ 内 / 会被转成表情）
COMMAND_START=["#", "!", ""]

# Bot 昵称（供 @Bot 触发时识别）
NICKNAME=[""]

# VRChat API 配置
VRC_USERNAME="你的VRChat邮箱"
VRC_PASSWORD="你的VRChat密码"
VRC_AUTH_COOKIE=""
VRC_TIMEOUT=30
VRC_REQUEST_DELAY=1000
